<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/panel_background">

    <ViewAnimator
        android:id="@+id/teletext_view_animator"
        android:inAnimation="@android:anim/fade_in"
        android:outAnimation="@android:anim/fade_out"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintDimensionRatio="1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminate="true"
                app:waveAmplitude="1dp"
                app:wavelength="10dp"/>

            <TextView
                android:id="@+id/teletext_loading_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="@string/teletext_page_loading"/>

            <TextView
                android:id="@+id/teletext_receiving_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="italic"
                tools:text="@string/teletext_page_receiving" />
        </LinearLayout>

        <de.hahnphilipp.watchwithfritzbox.utils.TeletextView
            android:id="@+id/teletextview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </ViewAnimator>

    <LinearLayout
        android:id="@+id/teletext_keypad_wrapper"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/teletext_view_animator"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/teletext_page_number_wrapper_shown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#2a2939"
                app:cardCornerRadius="8dp">

                <TextView
                    android:id="@+id/teletext_page_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:paddingHorizontal="32dp"
                    android:paddingVertical="16dp"
                    android:textSize="24sp"
                    tools:text="000" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="parent"
            android:layout_marginTop="16dp">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="1"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="2"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="3"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="4"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="5"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="6"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="7"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="8"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="9"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_page_down"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/round_arrow_back"
                    app:iconGravity="textStart"
                    style="?attr/materialIconButtonFilledStyle"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    android:text="0"
                    android:textColor="?colorOnPrimary"
                    app:cornerRadius="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/teletext_key_page_up"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/round_arrow_forward"
                    style="?attr/materialIconButtonFilledStyle"
                    android:insetLeft="4dp"
                    android:insetTop="4dp"
                    android:insetRight="4dp"
                    android:insetBottom="4dp"
                    app:iconGravity="textEnd" />
            </TableRow>
        </TableLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:padding="4dp">

            <Button
                android:id="@+id/extra_key_red"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_left_wrapper"
                android:focusable="true"
                android:nextFocusRight="@string/extra_key_green"
                android:nextFocusDown="@id/teletext_keys_hide"
                android:text="@string/extra_key_red"
                android:textColor="#fff"
                android:theme="@style/RedButton" />

            <Button
                android:id="@+id/extra_key_green"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_center_wrapper"
                android:focusable="true"
                android:nextFocusLeft="@string/extra_key_red"
                android:nextFocusRight="@string/extra_key_yellow"
                android:nextFocusDown="@id/teletext_keys_hide"
                android:text="@string/extra_key_green"
                android:textColor="#000"
                android:theme="@style/GreenButton" />

            <Button
                android:id="@+id/extra_key_yellow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_center_wrapper"
                android:focusable="true"
                android:nextFocusLeft="@string/extra_key_green"
                android:nextFocusRight="@string/extra_key_blue"
                android:nextFocusDown="@id/teletext_keys_hide"
                android:text="@string/extra_key_yellow"
                android:textColor="#000"
                android:theme="@style/YellowButton" />

            <Button
                android:id="@+id/extra_key_blue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/button_right_wrapper"
                android:focusable="true"
                android:nextFocusLeft="@string/extra_key_yellow"
                android:nextFocusDown="@id/teletext_keys_hide"
                android:text="@string/extra_key_blue"
                android:textColor="#fff"
                android:theme="@style/BlueButton" />


        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/teletext_page_number_wrapper_hidden"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp">

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        style="?attr/materialIconButtonOutlinedStyle"
        android:id="@+id/teletext_keys_hide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:icon="@drawable/round_grid_off"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.IconButton.Small.Square"/>

</androidx.constraintlayout.widget.ConstraintLayout>